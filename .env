# =============================================================================
# Polymarket Intelligence Platform — Environment Variables
# VPS Configuration
#
# File ini ada di .gitignore — JANGAN commit ke Git
# Copy dari .env.example dan isi password yang benar
# =============================================================================

# ---- Database (PostgreSQL di host VPS) ----
DB_HOST=postgres_db
DB_PORT=5432
DB_DATABASE=polyintel
DB_USERNAME=sikapiapsby
DB_PASSWORD=P%40ssw0rd

# ---- Redis (di host VPS) ----
REDIS_HOST=redis_cache
REDIS_PORT=6379

# ---- Polymarket API ----
# Tidak wajib untuk public market data
POLYMARKET_API_KEY=

# ---- Collector Schedule ----
SNAPSHOT_INTERVAL_MINUTES=5
MARKET_SYNC_INTERVAL_MINUTES=60

# ---- HTTP Client ----
HTTP_CONNECT_TIMEOUT=10.0
HTTP_READ_TIMEOUT=30.0

# ---- Retry ----
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=2.0

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json
DEBUG_SQL=false

# ---- Collector Identity ----
COLLECTOR_VERSION=1.0.0

# ---- Safety Caps ----
GAMMA_PAGE_SIZE=100
SNAPSHOT_BATCH_SIZE=200

